<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:edit="using:AvaloniaEdit"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:models="using:AvaloniaDynamicLibraryTest.Models"
             xmlns:vm="using:AvaloniaDynamicLibraryTest.ViewModels"
             x:Class="AvaloniaDynamicLibraryTest.Views.LibraryGenerationView"
             x:DataType="vm:LibraryGenerationViewModel"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="460">
  <Grid ColumnDefinitions="240,6,*">
      <Grid RowDefinitions="Auto,6,*">
        <Border Background="#FFFFFF"
                BorderBrush="#D9E2EF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
          <Grid RowDefinitions="Auto,Auto,Auto"
                RowSpacing="8">
            <TextBlock Text="算法模板"
                       FontWeight="SemiBold" />
            <ComboBox Grid.Row="1"
                      ItemsSource="{Binding Algorithms}"
                      SelectedItem="{Binding SelectedAlgorithm}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:AlgorithmOption">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Row="2"
                    Content="编译动态库"
                    Command="{Binding GenerateCommand}"
                    HorizontalAlignment="Stretch"
                    Height="32" />
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Rows"
                      Background="#CBD5E1" />

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#D9E2EF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="8">
            <TextBlock Text="接口契约"
                       FontWeight="SemiBold" />
            <edit:TextEditor x:Name="InterfaceEditor"
                             Grid.Row="1"
                             FontFamily="Consolas"
                             FontSize="13"
                             Background="#FFFFFF"
                             Foreground="#111827"
                             IsReadOnly="True"
                             ShowLineNumbers="False"
                             WordWrap="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
          </Grid>
        </Border>
      </Grid>

      <GridSplitter Grid.Column="1"
                    Width="6"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    Background="#CBD5E1" />

      <Border Grid.Column="2"
              Background="#FFFFFF"
              BorderBrush="#D9E2EF"
              BorderThickness="1"
              CornerRadius="6"
              Padding="10">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="8">
          <TextBlock Text="实现源码"
                     FontWeight="SemiBold" />
          <edit:TextEditor x:Name="SourceEditor"
                           Grid.Row="1"
                           FontFamily="Consolas"
                           FontSize="14"
                           Background="#FFFFFF"
                           Foreground="#111827"
                           Focusable="True"
                           IsReadOnly="False"
                           ShowLineNumbers="True"
                           WordWrap="False"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto" />
        </Grid>
      </Border>
  </Grid>
</UserControl>
