<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:models="using:AvaloniaDynamicLibraryTest.Models"
             xmlns:vm="using:AvaloniaDynamicLibraryTest.ViewModels"
             x:Class="AvaloniaDynamicLibraryTest.Views.LibraryInvocationView"
             x:DataType="vm:LibraryInvocationViewModel"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="460">
  <Grid RowDefinitions="Auto,*"
        RowSpacing="8">
    <Border Background="#F8FAFC"
            BorderBrush="#D9E2EF"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8">
      <Grid ColumnDefinitions="Auto,Auto,Auto"
            ColumnSpacing="10">
        <Button Content="刷新"
                Command="{Binding RefreshDirectoryCommand}"
                MinWidth="78" />
        <Button Grid.Column="1"
                Content="删除"
                Command="{Binding DeleteSelectedCommand}"
                MinWidth="78" />
        <Button Grid.Column="2"
                Content="执行"
                Command="{Binding InvokeSelectedCommand}"
                MinWidth="88" />
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,8,360">
      <Border Background="#FFFFFF"
              BorderBrush="#D9E2EF"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="10">
          <TextBlock Text="动态库列表"
                     FontWeight="SemiBold" />

          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Libraries}"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:GeneratedLibraryItem">
                <Grid ColumnDefinitions="Auto,*,136,86"
                      ColumnSpacing="12"
                      MinHeight="42"
                      Margin="0,3">
                  <CheckBox IsChecked="{Binding IsSelected}"
                            VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1"
                              VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <TextBlock Grid.Column="2"
                             Text="{Binding LastWriteTimeText}"
                             Foreground="#475569"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding SizeText}"
                             Foreground="#475569"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="8"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    Background="#CBD5E1" />

      <Grid Grid.Column="2"
            RowDefinitions="150,8,*">
        <Border Background="#FFFFFF"
                BorderBrush="#D9E2EF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14">
          <Grid RowDefinitions="Auto,Auto,Auto"
                RowSpacing="10">
            <TextBlock Text="入参"
                       FontWeight="SemiBold" />
            <Grid Grid.Row="1"
                  ColumnDefinitions="72,*"
                  ColumnSpacing="10">
              <TextBlock Text="left"
                         VerticalAlignment="Center"
                         Foreground="#475569" />
              <u:NumericIntUpDown Grid.Column="1"
                                  Value="{Binding LeftValue, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch" />
            </Grid>
            <Grid Grid.Row="2"
                  ColumnDefinitions="72,*"
                  ColumnSpacing="10">
              <TextBlock Text="right"
                         VerticalAlignment="Center"
                         Foreground="#475569" />
              <u:NumericIntUpDown Grid.Column="1"
                                  Value="{Binding RightValue, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch" />
            </Grid>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Rows"
                      Background="#CBD5E1" />

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#D9E2EF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="10">
            <TextBlock Text="执行结果"
                       FontWeight="SemiBold" />
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding InvocationResults}"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:LibraryInvocationResult">
                  <Border Padding="8"
                          Margin="0,2"
                          Background="#F8FAFC"
                          CornerRadius="4">
                    <TextBlock Text="{Binding DisplayText}"
                               TextWrapping="Wrap" />
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
